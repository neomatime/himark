{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "SESSION_BOOKING_SCREEN": []
  },
  "screens": [
    {
      "id": "SESSION_BOOKING_SCREEN",
      "title": "Book your session",
      "terminal": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Strategic Advisory Session"
          },
          {
            "type": "TextBody",
            "text": "Pick a preferred date and time. A principal confirms within one working day. All times are SAST (UTC+2)."
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "TextInput",
                "name": "full_name",
                "label": "Full name",
                "required": true,
                "input-type": "text",
                "helper-text": "First and last name"
              },
              {
                "type": "TextInput",
                "name": "email",
                "label": "Email address",
                "required": true,
                "input-type": "email"
              },
              {
                "type": "TextInput",
                "name": "phone",
                "label": "Contact number",
                "required": false,
                "input-type": "phone",
                "helper-text": "Optional"
              },
              {
                "type": "DatePicker",
                "name": "session_date",
                "label": "Preferred date",
                "required": true,
                "helper-text": "Weekdays only - principal confirms within 1 working day"
              },
              {
                "type": "Dropdown",
                "name": "session_time",
                "label": "Preferred time (SAST)",
                "required": true,
                "data-source": [
                  { "id": "0900", "title": "09:00" },
                  { "id": "0930", "title": "09:30" },
                  { "id": "1000", "title": "10:00" },
                  { "id": "1030", "title": "10:30" },
                  { "id": "1100", "title": "11:00" },
                  { "id": "1130", "title": "11:30" },
                  { "id": "1300", "title": "13:00" },
                  { "id": "1330", "title": "13:30" },
                  { "id": "1400", "title": "14:00" },
                  { "id": "1430", "title": "14:30" },
                  { "id": "1500", "title": "15:00" },
                  { "id": "1530", "title": "15:30" },
                  { "id": "1600", "title": "16:00" },
                  { "id": "1630", "title": "16:30" }
                ]
              },
              {
                "type": "RadioButtonsGroup",
                "name": "session_format",
                "label": "Format",
                "required": true,
                "data-source": [
                  { "id": "video", "title": "Video call" },
                  { "id": "inperson", "title": "In person - Randburg" }
                ]
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Submit",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "full_name": "${form.full_name}",
                "email": "${form.email}",
                "phone": "${form.phone}",
                "session_date": "${form.session_date}",
                "session_time": "${form.session_time}",
                "session_format": "${form.session_format}"
              }
            }
          }
        ]
      }
    }
  ]
}
